#: forms.py:22
msgid "Create new repository"
msgstr "Neues Repositorium anlegen"

#: forms.py:27
msgid "Name for the new repository"
msgstr "Name des neuen Repositoriums"

#: forms.py:31 forms.py:71
msgid "GitHub repository"
msgstr "GitHub-Repositorium"

#: forms.py:33 forms.py:72
msgid "Please use the form username/repository or organization/repository."
msgstr ""
"Bitte verwenden Sie die Form Benutzername/Repositorium oder Organisation/"
"Repositorium."

#: forms.py:37
msgid "Export options"
msgstr "Optionen zum Exportieren"

#: forms.py:38
msgid "Warning: Existing content in GitHub will be overwritten"
msgstr "Warnung: Bestehende Inhalte in GitHub werden überschrieben"

#: forms.py:44
msgid "Select all export options"
msgstr "Alle Optionen auswählen"

#: forms.py:48
msgid "Commit message"
msgstr "Commitnachricht"

#: forms.py:57
msgid "A name for the new repository is required"
msgstr "Ein Name für das neue Repositorium ist erforderlich"

#: forms.py:60 forms.py:93
msgid "A GitHub repository is required"
msgstr "Ein GitHub-Repositorium ist erforderlich"

#: forms.py:65
msgid "Not my repository"
msgstr "Das Repositorium gehört mir nicht"

#: forms.py:66
msgid "Check if the repository you want to import from is not yours"
msgstr "Auswählen, wenn das Repositorium, aus dem Sie importieren möchten, nicht Ihres ist"

#: forms.py:76
msgid "Public GitHub repository"
msgstr "Öffentliches GitHub-Repositorium"

#: forms.py:77
msgid "Link of the public GitHub repository you want to import from"
msgstr "Link des öffentlichen GitHub-Repositoriums, aus dem Sie importieren möchten"

#: providers.py:266
msgid "The URL of the GitHub repository to send issues to."
msgstr "Die URL des GitHub-Repositoriums, an das Issues gesendet werden sollen"

#: forms.py:80
msgid "File path"
msgstr "Dateipfad"

#: forms.py:81
msgid "Branch, tag, or commit"
msgstr "Branch, Tag, oder Commit"

#: forms.py:90
msgid "A repository link is required"
msgstr "Ein Repositorium-Link ist erforderlich"

