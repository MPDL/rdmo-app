#: forms.py:22
msgid "Create new repository"
msgstr "Neues Repositorium anlegen"

#: forms.py:27
msgid "Name for the new repository"
msgstr "Name des neuen Repositoriums"

#: forms.py:31 forms.py:65
msgid "GitHub repository"
msgstr "GitHub Repositorium"

#: forms.py:33 forms.py:66
msgid "Please use the form username/repository or organization/repository."
msgstr ""
"Bitte verwenden Sie die Form Benutzername/Repositorium oder Organisation/"
"Repositorium."

#: forms.py:37
msgid "Export options"
msgstr "Optionen zum Exportieren"

#: forms.py:38
msgid "Warning: Existing content in GitHub will be overwritten"
msgstr "Warnung: Bestehende Inhalte in GitHub werden überschrieben"

#: forms.py:44
msgid "Select all export options"
msgstr "Alle Optionen auswählen"

#: forms.py:48
msgid "Commit message"
msgstr "Commitnachricht"

#: forms.py:57
msgid "A name for the new repository is required"
msgstr "Ein Name für das neue Repositorium ist erforderlich"

#: forms.py:60
msgid "A GitHub repository must be selected"
msgstr "Ein GitHub-Repositorium muss ausgewählt werden"

#: forms.py:68
msgid "File path"
msgstr "Dateipfad"

#: forms.py:69
msgid "Branch, tag, or commit"
msgstr "Branch, Tag, oder Commit"

#: mixins.py:51 mixins.py:120
msgid "GitHub callback error"
msgstr "GitHub-Callback-Fehler"

#: mixins.py:52
msgid "State parameter did not match."
msgstr "Der Parameter 'state' stimmt nicht überein"

#: mixins.py:103
msgid "GitHub App installation/update not successful"
msgstr "Die Installation/Aktualisierung der GitHub App war nicht erfolgreich"

#: mixins.py:104
msgid "No installation id found."
msgstr "Keine Installations-ID gefunden"

#: mixins.py:121
msgid "No redirect could be found."
msgstr "Kein redirect gefunden"

#: mixins.py:308
msgid "Update list"
msgstr "Liste aktualisieren"

#: mixins.py:309
msgid ""
"List of your accessible GitHub repositories (up to 10 repos will be shown here)."
msgstr "Liste der zugänglichen GitHub-Repositorien (bis zu 10 Repos werden hier angezeigt)."

#: providers.py:276
msgid "Add GitHub integration"
msgstr "GitHub-Integration hinzufügen"

#: providers.py:277
msgid "Send to GitHub"
msgstr "An GitHub senden"

#: providers.py:278
msgid ""
"This integration allows the creation of issues in arbitrary GitHub "
"repositories. The upload of attachments is not supported by GitHub."
msgstr ""
"Diese Integration ermöglicht die Erstellung von Issues in beliebigen GitHub-"
"Repositorien. Das Hochladen von Anhängen wird von GitHub nicht unterstützt."

#: providers.py:284
msgid "The URL of the GitHub repository to send issues to."
msgstr "Die URL des GitHub-Repositoriums, an das Issues gesendet werden sollen"

#: providers.py:289
msgid "The secret for a GitHub webhook to close a task (optional)."
msgstr ""
"Das 'secret' für einen GitHub-Webhook zum Schließen einer Aufgabe (optional)."

#: providers.py:388
msgid "Install App"
msgstr "App installieren"

#: providers.py:389
msgid "To connect to GitHub repos, you first need to install the MPDL app."
msgstr ""
"Die Verbindung zu GitHub-Repositorien erfordert die Installation der MPDL-"
"GitHubApp."

#: providers.py:396
msgid "Authorize App"
msgstr "App autorisieren"

#: providers.py:397
msgid "To connect to GitHub repos, you first need to authorize the MPDL app."
msgstr ""
"Die Verbindung zu GitHub-Repositorien erfordert die Autorisierung der MPDL-"
"GitHubApp."

#: templates/plugins/github_export_form.html:7
#: templates/plugins/github_export_form.html:9
msgid "Export to GitHub"
msgstr "Nach GitHub exportieren"

#: templates/plugins/github_export_success.html:7
msgid "Successful Export to GitHub"
msgstr "Erfolgreicher Export nach GitHub"

#: templates/plugins/github_export_success.html:12
msgid "successfully exported,could not be exported"
msgstr "erfolgreich exportiert,konnte nicht exportiert werden"

#: templates/plugins/github_export_success.html:17
msgid "Go to GitHub repo"
msgstr "Zum GitHub-Repositorium"
